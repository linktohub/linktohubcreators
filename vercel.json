{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://linktohub.vercel.app"
  },
  "functions": {
    "src/app/api/generate-pdf/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/suggest-product/route.ts": { "maxDuration": 30 },
    "src/app/api/ai/generate-brand/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/chat/route.ts": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/email/drip",
      "schedule": "0 10 * * *"
    }
  ]
}
